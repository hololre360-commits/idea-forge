# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paddle
VITE_PADDLE_VENDOR_ID=your-vendor-id
VITE_PADDLE_SANDBOX=true
PADDLE_API_KEY=your-paddle-api-key
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# AI Providers (at least one)
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
DEEPSEEK_API_KEY=sk-... # for DeepSeek via OpenAI compatible

# Optional: Default model settings
DEFAULT_QUICK_MODEL=deepseek
DEFAULT_FORGE_MODELS=deepseek,gemini,gpt